<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ================================================================
         来自 Spring Boot 应用程序配置的属性
         ================================================================ -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <springProperty scope="context" name="APP_NAME"    source="spring.application.name" defaultValue="app"/>
    <springProperty scope="context" name="APP_VERSION" source="spring.application.version" defaultValue="unknown"/>
    <springProperty scope="context" name="LOG_PATH"    source="logging.file.path"       defaultValue="logs"/>
    <springProperty scope="context" name="LOG_LEVEL"   source="logging.level.root"      defaultValue="INFO"/>

    <springProfile name="dev">
        <property name="FINAL_LOG_PATH" value="${LOG_PATH}/dev"/>
    </springProfile>
    <springProfile name="!dev">
        <property name="FINAL_LOG_PATH" value="${LOG_PATH}"/>
    </springProfile>

    <!-- ================================================================
         控制台输出端 – 彩色文本，用于本地/开发环境
         可见字段：时间戳, 级别, PID, 线程, 记录器, traceId, 消息
         ================================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p){highlight} %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} [%X{traceId}] %m%n%wEx</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ================================================================
         按大小和时间滚动的 JSON 日志文件 – 结构化输出供 ELK / Filebeat 使用
         Filebeat 会将 *.json.log 发送到 Logstash/Elasticsearch。
         每个字段都是 Elasticsearch 的一级字段。

         输出的字段：
           @timestamp      ISO-8601 UTC 格式时间
           level           INFO / WARN / ERROR … 级别
           logger_name     完整的类名
           thread_name     线程名
           message         日志消息正文
           stack_trace     异常 + 根本原因 (如果有，最大 4 KB)
           traceId         MDC – 由 TraceIdFilter 设置 (用于分布式追踪)
           app             spring.application.name (应用名)
           version         spring.application.version (应用版本)
           host            JVM 所在的主机名
           pid             操作系统进程 ID
           env             spring.profiles.active (通过 TraceIdFilter 在 MDC 中设置)
         ================================================================ -->
    <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${FINAL_LOG_PATH}/${APP_NAME}.json.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${FINAL_LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.json.log.gz</fileNamePattern>
            <maxFileSize>200MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>20GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">

            <!-- ==== 重命名内置字段以匹配 ELK/OTel 约定 ==== -->
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>

            <!-- ==== MDC: 提升 traceId 为顶层字段 ==== -->
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>requestUri</includeMdcKeyName>

            <!-- ==== 静态元数据字段 ==== -->
            <customFields>{"app":"${APP_NAME}","version":"${APP_VERSION}"}</customFields>

            <!-- ==== 运行时主机 / pid (通过 providers 获取) ==== -->
            <!-- 以隐式配置或已移除，因为 LogstashEncoder 不支持即席提供者标签 -->

            <!-- ==== 异常: 优先打印根本原因，最大深度 30，最大长度 4KB ==== -->
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerThrowable>30</maxDepthPerThrowable>
                <maxLength>4096</maxLength>
                <rootCauseFirst>true</rootCauseFirst>
                <exclude>sun\.reflect\..*</exclude>
                <exclude>java\.lang\.reflect\..*</exclude>
            </throwableConverter>

        </encoder>
    </appender>

    <!-- ================================================================
         异步包装器
         ================================================================ -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="CONSOLE"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <appender name="ASYNC_FILE_JSON" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE_JSON"/>
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- ================================================================
         抑制嘈杂的框架日志记录器
         ================================================================ -->
    <logger name="org.springframework"          level="WARN"/>
    <logger name="org.hibernate"                level="WARN"/>
    <logger name="com.zaxxer.hikari"            level="WARN"/>
    <logger name="org.apache.http"              level="WARN"/>

    <!-- ================================================================
         基于 Profile 的根级配置

         local        →  仅有彩色的控制台输出 (开发调试)
         dev / prod   →  仅输出到 JSON 文件，dev 放至 dev/ 子目录 (通过 Filebeat 发送至 ELK)
         default      →  控制台 + JSON 文件
         ================================================================ -->
    <springProfile name="local">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="dev | prod">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="ASYNC_FILE_JSON"/>
        </root>
    </springProfile>

    <springProfile name="!local &amp; !dev &amp; !prod">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE_JSON"/>
        </root>
    </springProfile>

</configuration>
